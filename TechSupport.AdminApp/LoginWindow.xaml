<Window x:Class="TechSupport.AdminApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TechSupport Login"
        Width="420" Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="{StaticResource BackgroundColor}">
        <Border Width="360" Padding="24" Background="{StaticResource CardColor}" CornerRadius="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="TechSupport Admin" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock Text="Bejelentkezés a közös backendhez" FontSize="12" Foreground="#6c757d" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Email vagy felhasználónév"/>
                <TextBox Text="{Binding Username}" />

                <TextBlock Text="Jelszó"/>
                <PasswordBox x:Name="PasswordBox" />

                <Button Content="Belépés" Height="40" Command="{Binding LoginCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Click="PasswordSync" Margin="0,16,0,0" />

                <TextBlock Text="A belépés után a rendszer a közös backendből tölt adatokat." TextWrapping="Wrap" Foreground="#6c757d" FontSize="12" Margin="0,18,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
