<Window x:Class="TechSupport.AdminApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TechSupport Admin"
        Width="900" Height="500">

	<Grid Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="2*"/>
			<ColumnDefinition Width="3*"/>
		</Grid.ColumnDefinitions>

		<!-- Form panel -->
		<StackPanel>
			<TextBlock Text="Component Management"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>

			<TextBlock Text="PartName"/>
			<TextBox Text="{Binding PartName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

			<TextBlock Text="PartDescription"/>
			<TextBox Text="{Binding PartDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

			<TextBlock Text="PartVisible"/>
			<CheckBox Command="{Binding PartVisible, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

			<StackPanel Orientation="Horizontal" Margin="0,10,0,0">
				<Button Content="Add" Command="{Binding AddCommand}" Width="80" Margin="0,0,8,0"/>
				<Button Content="Update" Command="{Binding UpdateCommand}" Width="80" Margin="0,0,8,0"/>
				<Button Content="Delete" Command="{Binding DeleteCommand}" Width="80" Margin="0,0,8,0"/>
				<Button Content="Load" Command="{Binding LoadCommand}" Width="80"/>
			</StackPanel>
		</StackPanel>

		<!-- DataGrid -->
		<DataGrid Grid.Column="1"
                  ItemsSource="{Binding Components}"
                  SelectedItem="{Binding SelectedComponent}"
				  SelectionMode="Single"
                  AutoGenerateColumns="True"
                  Margin="10,0,0,0"/>
	</Grid>
</Window>
