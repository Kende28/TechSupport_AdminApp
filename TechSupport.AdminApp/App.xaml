<Application x:Class="TechSupport.AdminApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TechSupport.AdminApp"
             StartupUri="LoginWindow.xaml">

	<Application.Resources>
		<!-- Globális színek -->
		<SolidColorBrush x:Key="PrimaryColor" Color="Blue"/>
		<SolidColorBrush x:Key="SecondaryColor" Color="white"/>
		<SolidColorBrush x:Key="ErrorColor" Color="Red"/>

		<!-- Globális stílus a gombokhoz -->
		<Style TargetType="Button">
			<Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="6,3"/>
			<Setter Property="Margin" Value="2"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>

		<!-- Globális stílus a TextBox-okhoz -->
		<Style TargetType="TextBox">
			<Setter Property="Margin" Value="0,0,0,8"/>
			<Setter Property="Padding" Value="4"/>
		</Style>

		<!-- Globális stílus a PasswordBox-hoz -->
		<Style TargetType="PasswordBox">
			<Setter Property="Margin" Value="0,0,0,8"/>
			<Setter Property="Padding" Value="4"/>
		</Style>

		<!-- Globális stílus a TextBlock-okhoz -->
		<Style TargetType="TextBlock">
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>
	</Application.Resources>
</Application>
